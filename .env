# Absensi API - Backend Config
# Copy this file to .env and update values as needed

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=absensi_db
DB_USER=root
DB_PASS=

# Application Settings
APP_NAME=Sistem Absensi
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/absensi_api

# Upload Settings
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/jpg

# Security Settings
JWT_SECRET=your-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRY=86400

# CORS Settings
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# Logging
LOG_LEVEL=debug
LOG_PATH=./logs

# Timezone
TIMEZONE=Asia/Jakarta

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_DEVICE_BINDING=true
ENABLE_LOCATION_VERIFICATION=true
